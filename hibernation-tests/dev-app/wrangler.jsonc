{
  "name": "capnweb-dev-app",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-09",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "RPC_DO",
        "class_name": "RpcDurableObject"
      }
